PORT=3300
AGENT_DID=did:agent:compliance-risk-auditor
AGENT_AUTH_MODE=simple
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2-mini
MCP_HTTP_URL=https://your-mcp-server.example.com/rpc

# Platform -> Agent inbound auth (used in all modes)
PLATFORM_JWKS_URL=https://platform.example.com/.well-known/jwks.json
PLATFORM_JWT_ISSUER=federated-agent-platform

# Optional migration fallback for old platform HMAC forwarding
# ALLOW_LEGACY_PLATFORM_HMAC=false

# Simple mode
# Optional for legacy inbound HMAC fallback only
AGENT_SECRET=agt_sk_your_agent_secret_here
AGENT_API_KEY=agt_sk_your_agent_secret_here

# Advanced mode outbound signing
AGENT_SIGNATURE_ALGORITHM=RS256
AGENT_KEY_ID=agent-key-1
AGENT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
