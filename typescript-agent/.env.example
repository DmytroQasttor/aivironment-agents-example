# ---------------------------------------------
# Required Environment Variables
# ---------------------------------------------

# OpenAI API key (from https://platform.openai.com/)
# Used by your agent to call the OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Secret used to verify requests from your platform
# Must match the secret configured in your agent platform
AGENT_SECRET=your_agent_secret_here

# Port your agent will listen on
# Default: 3000
PORT=3000

# Model to use for test agent (use the cheapest available model)
# e.g., gpt-5.2-mini
OPENAI_MODEL=gpt-5.2-mini

# ---------------------------------------------
# Optional Environment Variables
# ---------------------------------------------

# MCP (Model Control Protocol) server endpoint
# (if your agent needs to call an MCP server)
MCP_ENDPOINT=https://your-mcp-server.example.com

# MCP authentication token
# (if required by your MCP server)
MCP_TOKEN=your_mcp_token_here