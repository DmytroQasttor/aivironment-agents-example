# ---------------------------------------------
# Runtime
# ---------------------------------------------

PORT=3000
AGENT_DID=did:agent:delivery-planning-coordinator
MCP_HTTP_URL=https://your-mcp-server.example.com/rpc
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2-mini

# ---------------------------------------------
# Inbound/Outbound Auth Mode
# ---------------------------------------------

# Allowed values: simple | advanced
AGENT_AUTH_MODE=simple

# ---------------------------------------------
# Simple mode credentials
# ---------------------------------------------

# Used to verify inbound platform HMAC signature
AGENT_SECRET=your_agent_secret_here

# Used for outbound MCP / platform calls
AGENT_API_KEY=agt_sk_your_agent_api_key_here

# ---------------------------------------------
# Advanced mode credentials
# ---------------------------------------------

# Platform JWT verification config (inbound)
PLATFORM_JWKS_URL=https://platform.example.com/.well-known/jwks.json
PLATFORM_JWT_ISSUER=https://platform.example.com

# Agent signing config (outbound)
AGENT_SIGNATURE_ALGORITHM=RS256
AGENT_KEY_ID=agent-key-1
AGENT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
